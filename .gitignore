# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
Generated\ Files/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Build intermediates
*.obj
*.pdb
*.ipdb
*.iobj
*.pch
*.ilk
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.binlog

# App packages
AppPackages/
BundleArtifacts/
*.appx
*.appxbundle
*.appxupload

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# C++ / MSVC
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cacheffile
*.VC.db
*.VC.VC.opendb

# Publish
publish/
*.[Pp]ublish.xml
*.azurePubxml

# Python (docs 构建用)
__pycache__/
*.pyc
.venv/
venv/

